rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowedEmail() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in [
             'r.kitagawa@g.caremax.co.jp',
             'k.ogura@g.caremax.co.jp'
           ];
    }

    function isValidMeta(data) {
      return data.keys().hasOnly(['moduleId', 'chunkCount', 'byteLength', 'savedAt', 'schemaVersion'])
        && data.keys().hasAll(['moduleId', 'chunkCount', 'byteLength', 'schemaVersion'])
        && data.moduleId is string
        && data.moduleId.size() > 0
        && data.moduleId.size() <= 128
        && data.chunkCount is int
        && data.chunkCount >= 0
        && data.chunkCount <= 10000
        && data.byteLength is int
        && data.byteLength >= 0
        && data.schemaVersion is int;
    }

    function isValidChunk(data) {
      return data.keys().hasOnly(['index', 'data'])
        && data.index is int
        && data.index >= 0
        && data.data is string
        && data.data.size() <= 200000;
    }

    match /kaientai_m_states/{moduleId} {
      allow read: if isAllowedEmail();
      allow create, update: if isAllowedEmail()
        && moduleId == request.resource.data.moduleId
        && isValidMeta(request.resource.data);
      allow delete: if isAllowedEmail();

      match /chunks/{chunkId} {
        allow read: if isAllowedEmail();
        allow create, update: if isAllowedEmail() && isValidChunk(request.resource.data);
        allow delete: if isAllowedEmail();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
